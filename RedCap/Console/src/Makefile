	  -c -o download.o `test -f 'engine/functions/download.c' || echo '$(srcdir)/'`engine/functions/download.c; \
	then mv -f "$(DEPDIR)/download.Tpo" "$(DEPDIR)/download.Po"; \
	else rm -f "$(DEPDIR)/download.Tpo"; exit 1; \
	fi
#	source='engine/functions/download.c' object='download.o' libtool=no \
#	depfile='$(DEPDIR)/download.Po' tmpdepfile='$(DEPDIR)/download.TPo' \
#	$(CCDEPMODE) $(depcomp) \
#	$(CC) $(DEFS) $(DEFAULT_INCLUDES) $(INCLUDES) $(AM_CPPFLAGS) $(CPPFLAGS) $(AM_CFLAGS) $(CFLAGS) -c -o download.o `test -f 'engine/functions/download.c' || echo '$(srcdir)/'`engine/functions/download.c

